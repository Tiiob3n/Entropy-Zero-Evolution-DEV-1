		{
			dependencies: ["604613590598BFAF"]
			description: [
				"&fBienvenue ! Pour vous aider à bien démarrer, choisissez un objet de soutien utilitaire."
				" "
				"&fRéfléchissez bien, un seul choix est possible :"
				""
				"&d- Netherite Backpack :&f Pour les explorateurs (stockage massif dès le départ)."
				"&e- Time in a Bottle :&f Pour les ingénieurs (accélère le temps de vos machines)."
			]
			id: "465F0FBCE0785C70"
			rewards: [{
				exclude_from_claim_all: true
