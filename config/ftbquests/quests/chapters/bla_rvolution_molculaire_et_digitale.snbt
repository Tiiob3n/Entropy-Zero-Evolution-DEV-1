	quests: [
		{
			dependencies: ["323D227A8C597AFE"]
			description: [
				"&fL'Age 6 commence enfin. Ton premier objectif, c'est cette machine. Sans elle, t'es bloqué."
				" "
				"&fL'&5Infuseur&f va te permettre de modifier tes lingots au niveau atomique. J'ai un peu durci le craft avec de l'&bEnderium&f et du &6Signalum&f pour être sûr que t'as bien bossé l'Age 5 avant de venir ici."
				" "
				"&cAttention :&f Ça pompe une blinde de RF. Vérifie tes câbles avant de la brancher."
			]
			id: "1B0E5CC52EB833ED"
			rewards: [{
				count: 8
				id: "1F6D63A7163A8C5B"
				item: "mekanism:ingot_osmium"
				type: "item"
			}]
			subtitle: "&7\"Fini de rigoler avec les alliages de base\""
			tasks: [{
